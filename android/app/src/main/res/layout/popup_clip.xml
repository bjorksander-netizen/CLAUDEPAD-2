<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/glass_popup"
    android:padding="12dp">

    <TextView android:id="@+id/kCopy" style="@style/KeyGlass"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="⧉  copy" android:textSize="15sp" />

    <TextView android:id="@+id/kPaste" style="@style/KeyGlass"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:text="⎘  paste" android:textSize="15sp" />
</LinearLayout>
