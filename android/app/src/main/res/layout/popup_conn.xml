<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="215dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/glass_popup"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="koneksi pc"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        android:paddingStart="4dp"
        android:paddingBottom="8dp" />

    <TextView android:id="@+id/kWifi" style="@style/KeyGlass"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="📶  wifi" android:textSize="15sp" />

    <TextView android:id="@+id/kBluetooth" style="@style/KeyGlass"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:text="ᛒ  bluetooth" android:textSize="15sp" />

    <TextView android:id="@+id/kHotspot" style="@style/KeyGlass"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:text="((•))  hotspot" android:textSize="15sp" />
</LinearLayout>
