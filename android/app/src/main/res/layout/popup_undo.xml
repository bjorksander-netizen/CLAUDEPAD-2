<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/glass_popup"
    android:padding="12dp">

    <TextView android:id="@+id/kUndo" style="@style/KeyGlass"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:text="↩  undo" android:textSize="15sp" />

    <TextView android:id="@+id/kRedo" style="@style/KeyGlass"
        android:layout_width="match_parent" android:layout_height="52dp"
        android:layout_marginTop="8dp"
        android:text="↪  redo" android:textSize="15sp" />
</LinearLayout>
