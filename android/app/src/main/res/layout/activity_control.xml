<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootControl"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_scrim"
    android:fitsSystemWindows="true"
    android:padding="10dp">

    <!-- ============ Bar atas ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="4dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text"
            android:textSize="13sp"
            android:text="..." />

        <TextView
            android:id="@+id/tvPing"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:textSize="12sp"
            android:textColor="@color/text_muted"
            android:visibility="gone"
            android:text="" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btnRotate"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/glass_round"
            android:gravity="center"
            android:text="⤢"
            android:textColor="@color/text"
            android:textSize="18sp"
            android:contentDescription="Ubah orientasi" />

        <TextView
            android:id="@+id/btnDisconnect"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/glass_round"
            android:gravity="center"
            android:text="⏻"
            android:textColor="@color/red"
            android:textSize="16sp"
            android:contentDescription="Putuskan koneksi" />

        <TextView
            android:id="@+id/btnSettings"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/glass_round"
            android:gravity="center"
            android:text="⚙"
            android:textColor="@color/text"
            android:textSize="18sp"
            android:contentDescription="Setting" />
    </LinearLayout>

    <!-- ============ Trackpad ============ -->
    <com.bjorn.claudepad.TrackpadView
        android:id="@+id/trackpad"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="150dp" />

    <!-- ============ Tombol mouse ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/btnLeft"
            style="@style/KeyGlass"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:text="◐" />

        <TextView
            android:id="@+id/btnMiddle"
            style="@style/KeyGlass"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="⊙" />

        <TextView
            android:id="@+id/btnRight"
            style="@style/KeyGlass"
            android:layout_width="0dp"
            android:layout_weight="2"
            android:layout_marginStart="6dp"
            android:text="◑" />
    </LinearLayout>

    <!-- ============ Keyboard (di bawah kontrol mouse) ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/etType"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="46dp"
            android:background="@drawable/glass_input"
            android:gravity="center_vertical"
            android:text="ketik di sini"
            android:textColor="@color/text_muted"
            android:textSize="14sp"
            android:paddingHorizontal="14dp"
            android:maxLines="1"
            android:ellipsize="end"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/kEnter"
            style="@style/KeyGlassAccent"
            android:layout_width="56dp"
            android:layout_marginStart="6dp"
            android:text="⏎" />
    </LinearLayout>

    <!-- ============ Baris pintasan + dropdown Advance ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <TextView android:id="@+id/kCopy"   style="@style/KeyGlass" android:layout_width="0dp" android:layout_weight="1" android:text="⧉" />
        <TextView android:id="@+id/kPaste"  style="@style/KeyGlass" android:layout_width="0dp" android:layout_weight="1" android:layout_marginStart="6dp" android:text="⎘" />
        <TextView android:id="@+id/kUndo"   style="@style/KeyGlass" android:layout_width="0dp" android:layout_weight="1" android:layout_marginStart="6dp" android:text="↩" />
        <TextView android:id="@+id/kWinTab" style="@style/KeyGlass" android:layout_width="0dp" android:layout_weight="1" android:layout_marginStart="6dp" android:text="⊞" />
        <TextView android:id="@+id/btnAdvance" style="@style/KeyGlass" android:layout_width="0dp" android:layout_weight="1" android:layout_marginStart="6dp" android:text="⋯" />
    </LinearLayout>

    <!-- ============ Baris bawah: 2 kolom seimbang (tinggi TETAP agar
         trackpad di atasnya selalu kebagian ruang) ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="190dp"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:baselineAligned="false">

        <!-- Kolom kiri: volume + media -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:background="@drawable/glass_panel"
            android:padding="10dp">

            <com.bjorn.claudepad.VolumeSlider
                android:id="@+id/volumeSlider"
                android:layout_width="44dp"
                android:layout_height="match_parent" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_marginStart="10dp">

                <TextView android:id="@+id/mPlay" style="@style/KeyGlassAccent"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:text="⏯" android:textSize="20sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">
                    <TextView android:id="@+id/mPrev" style="@style/KeyGlass" android:layout_width="0dp"
                        android:layout_weight="1" android:layout_height="match_parent" android:text="⏮" />
                    <TextView android:id="@+id/mNext" style="@style/KeyGlass" android:layout_width="0dp"
                        android:layout_weight="1" android:layout_height="match_parent"
                        android:layout_marginStart="6dp" android:text="⏭" />
                </LinearLayout>

                <TextView android:id="@+id/mMute" style="@style/KeyGlass"
                    android:layout_width="match_parent" android:layout_height="0dp"
                    android:layout_weight="1" android:layout_marginTop="6dp"
                    android:text="🔇" android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Kolom kanan: D-Pad (ukuran panel SAMA dengan kolom kiri) -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:background="@drawable/glass_panel"
            android:padding="10dp">

            <com.bjorn.claudepad.DpadView
                android:id="@+id/dpad"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:layout_gravity="center" />
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
