<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootMain"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_scrim"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="CLAUDEPAD"
            android:textColor="@color/text"
            android:textSize="30sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="28dp"
            android:text="remote untuk windows"
            android:textColor="@color/text_muted"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/glass_panel"
            android:padding="16dp">

            <EditText
                android:id="@+id/etIp"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/glass_input"
                android:hint="alamat ip pc"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:paddingHorizontal="14dp"
                android:inputType="text"
                android:maxLines="1"
                android:importantForAutofill="no" />

            <EditText
                android:id="@+id/etPin"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/glass_input"
                android:hint="pin (8 digit)"
                android:textColorHint="@color/text_muted"
                android:textColor="@color/text"
                android:textSize="15sp"
                android:paddingHorizontal="14dp"
                android:inputType="number"
                android:maxLength="8"
                android:maxLines="1"
                android:importantForAutofill="no" />

            <TextView
                android:id="@+id/btnConnect"
                style="@style/KeyGlassAccent"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:text="hubungkan"
                android:textSize="15sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:id="@+id/btnScan"
                    style="@style/KeyGlass"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:text="cari otomatis"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/btnUsb"
                    style="@style/KeyGlass"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:layout_marginStart="8dp"
                    android:text="usb"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:textColor="@color/text_muted"
            android:textSize="13sp"
            android:text="" />

        <TextView
            android:id="@+id/btnSettings"
            style="@style/KeyGlass"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:text="⚙  setting"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
